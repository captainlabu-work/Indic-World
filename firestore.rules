rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection rules
    match /users/{userId} {
      // Authenticated users can read user docs (for profile display, etc.)
      allow read: if isAuthenticated();

      // Users can create their own document during signup
      allow create: if isAuthenticated();

      // Users can update their own document; admins can update any
      allow update: if isAuthenticated() &&
                      (request.auth.uid == resource.data.uid ||
                       resource.data.role == 'admin');

      // Only the user themselves or admins can delete
      allow delete: if isAuthenticated() &&
                      (request.auth.uid == resource.data.uid);
    }

    // Articles collection rules
    match /articles/{articleId} {
      // Anyone can read published articles; authenticated users can read all
      allow read: if resource.data.status == 'published' ||
                    isAuthenticated();

      // Authenticated users can create articles
      allow create: if isAuthenticated() &&
                      request.resource.data.authorId == request.auth.uid;

      // Authors can update their own articles; any authenticated user can
      // increment views on published articles; admin updates handled by role
      allow update: if isAuthenticated();

      // Authors can delete their own articles
      allow delete: if isOwner(resource.data.authorId);
    }

    // Site settings (homepage cover story, etc.) — public read, admin write
    match /siteSettings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Subscribers collection
    match /subscribers/{subscriberId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAuthenticated();
    }
  }
}
